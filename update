name: อัปเดตข่าวอัตโนมัติ

on:
  schedule:
    # รันทุกวัน เวลา 23:00 UTC = 06:00 น. เวลาไทย (วันถัดไป)
    - cron: "0 23 * * *"
  workflow_dispatch: {}   # ปุ่มกด "Run workflow" เพื่อรันเองได้ทันทีจากแท็บ Actions

permissions:
  contents: write   # ให้สิทธิ์ commit กลับเข้า repo

jobs:
  update-news:
    runs-on: ubuntu-latest
    steps:
      - name: ดึงโค้ดจาก repo
        uses: actions/checkout@v4

      - name: ติดตั้ง Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: รันสคริปต์ดึงข่าว
        run: python fetch_news.py

      - name: Commit และ push ถ้ามีข่าวใหม่
        run: |
          git config user.name "news-bot"
          git config user.email "news-bot@users.noreply.github.com"
          git add news.json
          if git diff --staged --quiet; then
            echo "ไม่มีข่าวใหม่ ข้ามการ commit"
          else
            git commit -m "อัปเดตข่าวอัตโนมัติ $(date -u +'%Y-%m-%d %H:%M UTC')"
            git push
          fi
